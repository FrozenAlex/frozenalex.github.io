---
import type { ImageMetadata } from "astro";
import { Picture } from "astro:assets";

interface Props {
  src: ImageMetadata;
  alt: string;
  size?: number;
}

const { src, alt, size = 280 } = Astro.props;
---

<span
  class="webgl-image"
  data-webgl-image
  style={`--webgl-image-size: ${size}px`}
>
  <Picture
    formats={["avif", "webp"]}
    sizes={`${size}px`}
    width={size}
    height={size}
    class="webgl-image__fallback"
    src={src}
    alt={alt}
  />
  <canvas
    class="webgl-image__canvas"
    aria-hidden="true"
    width={size}
    height={size}
  ></canvas>
</span>

<script>
  import { createWebGLImageRenderer } from "../lib/webgl/imageRenderer";
  import fragmentShaderSource from "../shaders/profile-image.frag.glsl?raw";
  import vertexShaderSource from "../shaders/profile-image.vert.glsl?raw";

  const roots = document.querySelectorAll<HTMLElement>("[data-webgl-image]");

  roots.forEach((root) => {
    if (root.dataset.webglInitialized === "true") return;

    const image = root.querySelector<HTMLImageElement>("img");
    const canvas = root.querySelector<HTMLCanvasElement>("canvas");
    if (!image || !canvas) return;

    root.dataset.webglInitialized = "true";

    const renderer = createWebGLImageRenderer({
      canvas,
      image,
      vertexShaderSource,
      fragmentShaderSource,
      onReady: () => {
        root.dataset.webglReady = "true";
      },
      onFallback: (error) => {
        delete root.dataset.webglReady;

        if (error) {
          console.warn("WebGL profile image fell back to the regular image.", error);
        }
      },
    });

    renderer.start();
    document.addEventListener("astro:before-swap", () => renderer.destroy(), {
      once: true,
    });
  });
</script>

<style>
  .webgl-image {
    position: relative;
    display: block;
    width: var(--webgl-image-size);
    height: var(--webgl-image-size);
    overflow: hidden;
    border-radius: 50%;
  }

  .webgl-image :global(picture),
  .webgl-image :global(img),
  .webgl-image__canvas {
    display: block;
    width: 100%;
    height: 100%;
  }

  .webgl-image :global(img) {
    object-fit: cover;
  }

  .webgl-image__canvas {
    position: absolute;
    inset: 0;
    opacity: 0;
    pointer-events: none;
  }

  .webgl-image[data-webgl-ready="true"] .webgl-image__canvas {
    opacity: 1;
  }
</style>
