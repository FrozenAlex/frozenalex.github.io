---
import { Icon } from "astro-icon/components";

interface Props {
    /**
     * If true, the toggle will be fixed to the bottom right corner of the screen
     */
    fixed?: boolean;
    /**
     *  Size of the icon in pixels (default: 27)
     */
    size?: number
}
const { fixed = false, size = 27 } = Astro.props;
---

<button
  type="button"
  aria-label="Toggle dark theme"
  aria-pressed="false"
  class:list={[
    "site-theme-toggle",
    { "fixed": fixed }
  ]}
>
  <Icon name="mdi:theme-light-dark" size={size} class="icond" />
</button>

<style lang="postcss">
  .site-theme-toggle {
    color: var(--text-color);
    background-color: transparent;
    border: 1px solid transparent;
    border-radius: 9999px;
    padding: 0.5rem;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
    z-index: 1000;
    transition:
      background-color 0.2s ease,
      border-color 0.2s ease,
      outline-color 0.2s ease;
  }

  .site-theme-toggle.fixed {
    position: fixed;
    bottom: 1rem;
    right: 1rem;
  }

  .site-theme-toggle:hover {
    background-color: rgb(127 127 127 / 0.12);
    border-color: currentColor;
  }

  .site-theme-toggle:focus-visible {
    outline: 3px solid var(--accent-color);
    outline-offset: 4px;
  }

  .icond {
    color: currentColor;
  }
</style>

<script lang="ts">
  const toggles = document.querySelectorAll(".site-theme-toggle");

  const prefersDark = () =>
    window.matchMedia("(prefers-color-scheme: dark)").matches;

  const getCurrentTheme = () => {
    const savedTheme = localStorage.getItem("theme");
    if (savedTheme === "dark" || savedTheme === "light") {
      return savedTheme;
    }

    return prefersDark() ? "dark" : "light";
  };

  const setTheme = (theme) => {
    document.body.classList.toggle("dark", theme === "dark");
    document.body.classList.toggle("light", theme === "light");

    toggles.forEach((toggle) => {
      toggle.setAttribute("aria-pressed", String(theme === "dark"));
    });
  };

  setTheme(getCurrentTheme());

  toggles.forEach((toggle) => {
    toggle.addEventListener("click", () => {
      const newTheme = getCurrentTheme() === "dark" ? "light" : "dark";
      setTheme(newTheme);
      localStorage.setItem("theme", newTheme);
    });
  });
</script>
